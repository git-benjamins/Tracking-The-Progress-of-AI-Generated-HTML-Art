<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Simple Turtle</title>
<style>
  body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: #e0f7fa;
  }

  .turtle {
    position: relative;
    width: 200px;
    height: 150px;
  }

  /* Shell */
  .shell {
    width: 150px;
    height: 100px;
    background: #4CAF50;
    border-radius: 50%;
    position: absolute;
    top: 25px;
    left: 25px;
  }

  /* Head */
  .head {
    width: 50px;
    height: 50px;
    background: #66bb6a;
    border-radius: 50%;
    position: absolute;
    top: 50px;
    right: -20px;
  }

  /* Eye */
  .eye {
    width: 8px;
    height: 8px;
    background: black;
    border-radius: 50%;
    position: absolute;
    top: 15px;
    left: 15px;
  }

  /* Legs */
  .leg {
    width: 30px;
    height: 30px;
    background: #66bb6a;
    border-radius: 50%;
    position: absolute;
  }

  .leg1 { top: 90px; left: 10px; }
  .leg2 { top: 90px; right: 10px; }
  .leg3 { top: 20px; left: 10px; }
  .leg4 { top: 20px; right: 10px; }

  /* Tail */
  .tail {
    width: 20px;
    height: 20px;
    background: #66bb6a;
    position: absolute;
    top: 65px;
    left: -10px;
    transform: rotate(45deg);
  }
</style>
</head>
<body>

<div class="turtle">
  <div class="shell"></div>
  <div class="head">
    <div class="eye"></div>
  </div>
  <div class="leg leg1"></div>
  <div class="leg leg2"></div>
  <div class="leg leg3"></div>
  <div class="leg leg4"></div>
  <div class="tail"></div>
</div>

</body>
</html>
