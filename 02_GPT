<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Realistic Turtle</title>
<style>
  body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background: linear-gradient(#b2ebf2, #e0f7fa);
  }

  .turtle {
    position: relative;
    width: 260px;
    height: 180px;
  }

  /* Shell (with pattern + shading) */
  .shell {
    width: 200px;
    height: 130px;
    background: radial-gradient(circle at 40% 40%, #66bb6a, #2e7d32);
    border-radius: 50%;
    position: absolute;
    top: 25px;
    left: 30px;
    box-shadow: inset -10px -10px 20px rgba(0,0,0,0.4);
    overflow: hidden;
  }

  /* Shell pattern */
  .pattern {
    position: absolute;
    width: 100%;
    height: 100%;
    background-image: 
      repeating-radial-gradient(circle, transparent 0 18px, rgba(0,0,0,0.2) 18px 20px);
    opacity: 0.4;
  }

  /* Head */
  .head {
    width: 60px;
    height: 60px;
    background: radial-gradient(circle at 30% 30%, #81c784, #388e3c);
    border-radius: 50%;
    position: absolute;
    top: 55px;
    right: -10px;
  }

  /* Eye */
  .eye {
    width: 10px;
    height: 10px;
    background: black;
    border-radius: 50%;
    position: absolute;
    top: 18px;
    left: 18px;
  }

  .eye::after {
    content: '';
    width: 4px;
    height: 4px;
    background: white;
    border-radius: 50%;
    position: absolute;
    top: 2px;
    left: 2px;
  }

  /* Legs */
  .leg {
    width: 45px;
    height: 35px;
    background: radial-gradient(circle at 30% 30%, #81c784, #2e7d32);
    border-radius: 50%;
    position: absolute;
  }

  .leg1 { bottom: 5px; left: 40px; transform: rotate(10deg); }
  .leg2 { bottom: 5px; right: 40px; transform: rotate(-10deg); }
  .leg3 { top: 35px; left: 35px; transform: rotate(-15deg); }
  .leg4 { top: 35px; right: 35px; transform: rotate(15deg); }

  /* Tail */
  .tail {
    width: 25px;
    height: 25px;
    background: linear-gradient(45deg, #66bb6a, #2e7d32);
    position: absolute;
    top: 75px;
    left: 10px;
    transform: rotate(45deg);
    border-radius: 5px;
  }
</style>
</head>
<body>

<div class="turtle">
  <div class="shell">
    <div class="pattern"></div>
  </div>

  <div class="head">
    <div class="eye"></div>
  </div>

  <div class="leg leg1"></div>
  <div class="leg leg2"></div>
  <div class="leg leg3"></div>
  <div class="leg leg4"></div>

  <div class="tail"></div>
</div>

</body>
</html>
